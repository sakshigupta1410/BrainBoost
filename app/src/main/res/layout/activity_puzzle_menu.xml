<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="top"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="366dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:layout_marginTop="12dp"
        android:gravity="center_horizontal"
        android:text="PUZZLE GAME"
        android:textColor="#28282B"
        android:textSize="24sp"
        android:textStyle="bold" />
    <!-- Beginner Label -->
    <TextView
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_gravity="left"
        android:layout_marginBottom="18dp"
        android:text="Are You a Beginner...??"
        android:textColor="#202F89"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 8 Puzzle Button -->
    <Button
        android:id="@+id/btn8Puzzle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="8-Puzzle"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:layout_marginBottom="28dp"
        android:backgroundTint="@color/green"
        />

    <!-- Pro Label -->
    <TextView
        android:layout_width="356dp"
        android:layout_height="wrap_content"
        android:layout_gravity="left"
        android:layout_marginBottom="18dp"
        android:text="Or a Pro??"
        android:textColor="#202F89"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 15 Puzzle Button -->
    <Button
        android:id="@+id/btn15Puzzle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="15-Puzzle"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/green"
        />

</LinearLayout>
