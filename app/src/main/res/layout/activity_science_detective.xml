<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gradient">

    <LinearLayout
        android:id="@+id/gameContainer"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvGameTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCIENCE DETECTIVE"
            android:letterSpacing="0.1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <!-- SCORE -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score: 0"
            android:textStyle="bold"
            android:textColor="#031C2F"
            android:textSize="18sp"
            android:layout_marginTop="30dp" />

        <!-- QUESTION BOX -->
        <LinearLayout
            android:id="@+id/questionBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D5E9F8"
            android:padding="18dp"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question"
                android:textColor="#311B92"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- OPTIONS -->
        <Button
            android:id="@+id/btnOption1"
            android:text="Option 1"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:background="@drawable/bg_option_default"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnOption2"
            android:text="Option 2"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_option_default"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnOption3"
            android:text="Option 3"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_option_default"
            android:textColor="#FFFFFF" />

        <!-- EXPLANATION -->
        <TextView
            android:id="@+id/tvExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#070000"
            android:textSize="16sp"
            android:layout_marginTop="25dp" />

        <!-- NEXT BUTTON -->
        <Button
            android:id="@+id/btnNext"
            android:text="Next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:backgroundTint="@color/green"
            android:textColor="#ECEAEF" />

        <!-- RESULT LAYOUT (FIXED POSITION) -->
        <LinearLayout
            android:id="@+id/resultLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#FFFFFF"
            android:elevation="8dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quiz Completed 🎉"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#283593"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvFinalScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Score"
                android:textSize="18sp"
                android:textColor="#424242"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvPerformance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Performance"
                android:textSize="16sp"
                android:textColor="#43A047"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="RESTART QUIZ"
                android:layout_marginTop="20dp"
                android:backgroundTint="#7E57C2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <Button
                android:id="@+id/btnExit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="EXIT"
                android:layout_marginTop="14dp"
                android:backgroundTint="#B0BEC5"
                android:textColor="#000000"
                android:letterSpacing="0.08"/>

        </LinearLayout>
    </LinearLayout>

</ScrollView>