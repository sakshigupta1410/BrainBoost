<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_soft_gradient">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:text="SUDOKU"
            android:letterSpacing="0.1"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#222"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvTimer"
            android:text="⏱ 00:00"
            android:textSize="18sp"
            android:textColor="#CC1818"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- SUDOKU GRID (SAFE HEIGHT) -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_gravity="center"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <com.example.brainboost.SudokuView
            android:id="@+id/sudokuView"
            android:layout_width="360dp"
            android:layout_height="360dp"
            android:padding="0dp"/>
    </androidx.cardview.widget.CardView>


    <!-- NUMBER PAD -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginTop="15dp"

        android:useDefaultMargins="true">

        <Button android:id="@+id/btn1" android:text="1" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn2" android:text="2" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn3" android:text="3" style="@style/SudokuButton"/>

        <Button android:id="@+id/btn4" android:text="4" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn5" android:text="5" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn6" android:text="6" style="@style/SudokuButton"/>

        <Button android:id="@+id/btn7" android:text="7" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn8" android:text="8" style="@style/SudokuButton"/>
        <Button android:id="@+id/btn9" android:text="9" style="@style/SudokuButton"/>

        <Button
            android:id="@+id/btnClear"
            android:text="CLEAR"
            android:textStyle="bold"
            android:textColor="#000"
            android:backgroundTint="#CCFBF1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_columnSpan="3"/>
    </GridLayout>

    <!-- RESULT SCREEN -->
    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="24dp"
        android:background="#CC000000">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉 Sudoku Solved!"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvFinalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time: 00:00"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="New Game"
            android:textAllCaps="false"
            android:backgroundTint="#7E57C2"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btnExit"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Exit"
            android:textAllCaps="false"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</LinearLayout>
