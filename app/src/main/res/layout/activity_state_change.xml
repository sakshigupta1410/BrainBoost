<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvSequenceTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Drag molecule to correct state"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#C8E6C9"
        android:gravity="center"/>


    <TextView
        android:id="@+id/moleculeItem"
        android:text="CO₂"
        android:textSize="26sp"
        android:padding="20dp"
        android:background="#BBDEFB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="120dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView android:id="@+id/solidBox" android:text="Solid"
            android:layout_weight="1" android:gravity="center"
            android:padding="20dp"
            android:background="#CFD8DC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView android:id="@+id/liquidBox" android:text="Liquid"
            android:layout_weight="1" android:gravity="center"
            android:padding="20dp"
            android:background="#B3E5FC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView android:id="@+id/gasBox" android:text="Gas"
            android:layout_weight="1" android:gravity="center"
            android:padding="20dp"
            android:background="#FFCCBC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>